# ═══════════════════════════════════════════════
#   MediSense AI — Android .gitignore
# ═══════════════════════════════════════════════

# ── Gradle build outputs ─────────────────────
build/
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# ── APK / AAB release files ──────────────────
*.apk
*.aab
*.ap_
*.dex

# ── Android Studio / IntelliJ IDEA ───────────
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/
.externalNativeBuild/
.cxx/

# ── Local machine config (NEVER commit) ──────
local.properties

# ── Signing / Keystore (NEVER commit) ────────
*.jks
*.keystore
keystore.properties
release/
signing/

# ── Lint & test outputs ───────────────────────
lint/
lint-results*
*.lint
test-results/
androidTest-results/

# ── Profiling & logs ──────────────────────────
*.hprof
*.log
proguard/
mapping.txt

# ── macOS system files ────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows system files ──────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux system files ────────────────────────
*~

# ── Node / npm (if any tooling used) ─────────
node_modules/
npm-debug.log*

# ── Firebase (if added later) ─────────────────
google-services.json

# ── Environment / secrets ─────────────────────
.env
.env.local
secrets.properties
